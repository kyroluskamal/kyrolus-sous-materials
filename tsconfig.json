{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "kyrolus-sous-materials": [
        "./dist/kyrolus-sous-materials"
      ],
      "kyrolus-sous-materials/*": [
        "./dist/kyrolus-sous-materials/*"
      ],
      "@ks-jit/browser": [
        "./projects/kyrolus-sous-materials/jit/src/browser"
      ]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "types": [
      "./node_modules/user-agent-data-types"
     ]
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/kyrolus-sous-materials/tsconfig.lib.json"
    },
    {
      "path": "./projects/kyrolus-sous-materials/tsconfig.spec.json"
    },
    {
      "path": "./projects/ks-materials-docs/tsconfig.app.json"
    },
    {
      "path": "./projects/ks-materials-docs/tsconfig.spec.json"
    }
  ]
}
